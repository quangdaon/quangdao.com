---
import { getEntryBySlug } from 'astro:content';
import Comic from './Comic.astro';

interface Props {
  slug: string;
}

const { slug } = Astro.props;

const comic = await getEntryBySlug('comics', slug);
---
{comic && 
  <h1 id={comic.slug}>
    {comic.data.title}
  </h1>
  
  <Comic {...comic} />
  
  <a href={`/comics/${comic.slug}#transcript`}>View Transcript</a>
}