---
import type { CollectionEntry } from 'astro:content';

type Props = CollectionEntry<'comics'>;

const { slug, data } = Astro.props;
const { title, alt } = data;
---

<a
  href={`/images/comics/large/${slug}.png`}
  title="View Large Image"
  target="_blank"
>
  <img src={`/images/comics/web/${slug}.png`} alt={alt || title} />
</a>
