---
import type { CollectionEntry } from 'astro:content';

type Props = CollectionEntry<'comics'>['data'];

const { title, slug, alt } = Astro.props;
---

<a
  href={`/images/comics/large/${slug}.png`}
  title="View Large Image"
  target="_blank"
>
  <img src={`/images/comics/web/${slug}.png`} alt={alt || title} />
</a>
